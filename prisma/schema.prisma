generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                 String          @id @default(cuid())
  name               String?
  email              String?         @unique
  password           String?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  emailVerified      DateTime?
  image              String?
  marketAccessExpiry DateTime?
  role               String          @default("farmer")
  Account            Account[]
  chatSessions       ChatSession[]
  farms              Farm[]
  listings           MarketListing[]
  payments           Payment[]
  Session            Session[]
  vendorMessages     VendorMessage[]
  notificationsEnabled Boolean       @default(true)
}

model Payment {
  id          String   @id @default(cuid())
  userId      String
  amount      Float
  currency    String   @default("KES")
  status      String   @default("PENDING")
  reference   String?
  externalId  String?
  phoneNumber String?
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Farm {
  id        String   @id @default(cuid())
  name      String
  location  String?
  size      Float?
  layout    Json?
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  blocks    Block[]
  employees Employee[]
  tasks     Task[]
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Block {
  id          String          @id @default(cuid())
  name        String
  cropType    String?
  area        Float?
  farmId      String
  status      String          @default("active")
  plantedDate DateTime?
  harvestDate DateTime?
  gridConfig  Json?
  farm        Farm            @relation(fields: [farmId], references: [id], onDelete: Cascade)
  sensors     Sensor[]
  readings    SensorReading[]
  recommendations DailyRecommendation[]
  tasks       Task[]
}

model Sensor {
  id       String          @id @default(cuid())
  name     String
  type     String
  blockId  String
  status   String          @default("active")
  lastSeen DateTime        @default(now())
  block    Block           @relation(fields: [blockId], references: [id], onDelete: Cascade)
  readings SensorReading[]
}

model SensorReading {
  id         Int      @id @default(autoincrement())
  blockId    String?
  moisture   Float?
  temp       Float?
  data       Json?
  humidity   Float?
  nitrogen   Float?
  phosphorus Float?
  potassium  Float?
  sensorId   String
  timestamp  DateTime @db.Timestamptz(6)
  unit       String?
  value      Float?
  block      Block?   @relation(fields: [blockId], references: [id])
  sensor     Sensor   @relation(fields: [sensorId], references: [id], onDelete: Cascade)
}

model ChatSession {
  id        String        @id @default(cuid())
  userId    String
  title     String?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  messages  ChatMessage[]
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ChatMessage {
  id            String      @id @default(cuid())
  sessionId     String
  role          String
  content       String
  language      String?
  imageAnalysis Json?
  actions       Json?
  createdAt     DateTime    @default(now())
  session       ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

model MarketListing {
  id          String   @id @default(cuid())
  title       String
  description String
  price       Float
  quantity    String
  location    String
  imageUrl    String?
  sellerId    String
  status      String   @default("ACTIVE")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  seller      User     @relation(fields: [sellerId], references: [id], onDelete: Cascade)
}

model DailyRecommendation {
  id          String   @id @default(cuid())
  blockId     String
  date        DateTime @default(now()) 
  type        String   @default("general") // e.g., 'irrigation', 'fertilizer', 'general'
  content     String
  isCompleted Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime? @updatedAt

  block       Block    @relation(fields: [blockId], references: [id], onDelete: Cascade)
}

model Account {
  id                String  @id
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  User              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id
  sessionToken String   @unique
  userId       String
  expires      DateTime
  User         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Employee {
  id          String   @id @default(cuid())
  farmId      String
  name        String
  role        String
  phoneNumber String?
  email       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  farm        Farm     @relation(fields: [farmId], references: [id], onDelete: Cascade)
  tasks       Task[]
}

model Task {
  id          String    @id @default(cuid())
  farmId      String
  blockId     String?
  employeeId  String?
  title       String
  description String?
  status      String    @default("PENDING") // PENDING, IN_PROGRESS, COMPLETED
  priority    String    @default("MEDIUM")  // LOW, MEDIUM, HIGH
  dueDate     DateTime?
  completedAt DateTime?
  reminder1hSent    Boolean @default(false)
  reminder10mSent   Boolean @default(false)
  overdueNoticeSent Boolean @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  farm        Farm      @relation(fields: [farmId], references: [id], onDelete: Cascade)
  block       Block?    @relation(fields: [blockId], references: [id], onDelete: SetNull)
  assignee    Employee? @relation(fields: [employeeId], references: [id], onDelete: SetNull)
}

model VendorMessage {
  id          String   @id @default(cuid())
  userId      String
  vendorName  String
  content     String
  isFromUser  Boolean  @default(true)
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
