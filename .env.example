AUTH_SECRET="your-auth-secret-string"

# GitHub Models (Free AI inference)
GITHUB_TOKEN="your-github-personal-access-token"
GITHUB_MODEL="gpt-4o"
GITHUB_MODELS_ENDPOINT="https://models.inference.ai.azure.com/chat/completions"

# Azure Translator
AZURE_TRANSLATOR_ENDPOINT="https://api.cognitive.microsofttranslator.com/"
AZURE_TRANSLATOR_KEY="your-azure-translator-key"
AZURE_TRANSLATOR_REGION="eastus"

# Azure Speech Service
AZURE_SPEECH_KEY="your-azure-speech-key"
AZURE_SPEECH_REGION="eastus"
AZURE_SPEECH_ENDPOINT="https://your-speech-resource.cognitiveservices.azure.com/"

# Azure Computer Vision
AZURE_VISION_ENDPOINT="https://your-vision-resource.cognitiveservices.azure.com/"
AZURE_VISION_KEY="your-azure-vision-key"
AZURE_VISION_REGION="eastus"

# Text Embedding (for future use)
AZURE_EMBEDDING_DEPLOYMENT="text-embedding-ada-002"

# OpenWeatherMap API
OPENWEATHER_API_KEY="your-openweathermap-api-key"

# Database Configuration
DATABASE_URL="postgresql://username:password@host:port/database?sslmode=require"
DIRECT_URL="postgresql://username:password@host:port/database?sslmode=require"

# Local Ollama (chat advisor)
OLLAMA_URL="http://localhost:11434/v1/chat/completions"
OLLAMA_MODEL="qwen2.5:0.5b"
# Use a larger multilingual model for non-English (e.g. aya:latest, llama3.1:8b)
OLLAMA_MULTILINGUAL_MODEL="aya:latest"

# Azure Translator — required for reliable Swahili etc. when using a small Ollama model
AZURE_TRANSLATOR_KEY="your-azure-translator-key"
AZURE_TRANSLATOR_REGION="eastus"
